{
  "name": "dither-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Composable, dithered charts for shadcn/ui — area, line, bar, pie & radar on a tiny ordered-dither canvas engine.",
  "homepage": "https://tripwire.sh/dither-kit",
  "repository": {
    "type": "git",
    "url": "https://github.com/Boring-Software-Inc/dither-kit.git"
  },
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:registry && npm run build:cli",
    "build:core": "npm run build -w @dither-kit/registry-core",
    "build:cli": "npm run build -w @dither-kit/cli",
    "build:registry": "tsx scripts/build-registry.mts",
    "test": "vitest run && npm run test -w @dither-kit/cli"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "clsx": "^2.1.1",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "happy-dom": "^15.11.7",
    "motion": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
